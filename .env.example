ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://multi_agent:multi_agent@postgres:5432/multi_agent
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

TAVILY_API_KEY=
SERPER_API_KEY=

VECTOR_BACKEND=chroma
CHROMA_PATH=./.chroma
PINECONE_API_KEY=
PINECONE_INDEX=agent-memory

DEFAULT_BUDGET_USD=2.00
MAX_ITERATIONS=8
AGENT_TIMEOUT_SECONDS=120
CODE_SANDBOX_TIMEOUT_SECONDS=10

